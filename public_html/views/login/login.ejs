<%- include('../includes/head.ejs') %>


<link rel="stylesheet" href="/css/style.css">
<link rel="stylesheet" href="/css/login.css">



<body>
<%- include('../includes/navigation.ejs') %>

<div class="auth-container">
	<div class="auth-panel">
		<div class="auth-panel-header"><h1>Salut!</h1> <br><h3>Logheaza-te in cont</h3></div>
		<div class="auth-panel-body">
			<form name="user_login" action="/login/" method="post">
				<div class="auth-form-group">
					<label for="auth-label-user-login-email" class="auth-label-user-login-email">Introdu adresa de email</label>
					<input type="email" id="auth-input-user-login-email" name="email" value="" class="auth-input-email">
				</div>
				<div class="auth-form-group">
					<label for="auth-user-login-password" class="auth-user-login-password">Introdu parola</label>
					<input type="password" id="auth-user-login-password" name="password" value="" class="auth-input-email" >
				</div>
				<div class="auth-form-group">
					<input type="hidden" name="_csrf" value="<%= csrfToken %>">
					<button type="submit" id="" name=""	class="btn-primary auth-btn">Continua</button>
				</div>
			</form>
			<!-- <div class="auth-text-hr-line">
			</div>
			<div class="auth-login-text">Nu ai cont? <br> Poti crea unul la pasul urmator</div>
			<div class="text-muted mt-sm"> -->
				<div class="auth-text-hr-line">
					<span>sau</span>
				</div>
				<div>intra in cont cu</div>
			</div>
			<div class="auth-social-text">
				<a href="/" class="btn btn-social google mt-md">Google</a>
				<a href="/" class="btn btn-social facebook mt-md">Facebook</a>
			</div>
		</div>
	</div>
	<div class="auth-help">
		<a href="/" class="auth-link-help">Ai Nevoie de ajutor?</a>
	</div>
</div>

<%- include('../includes/end.ejs') %>
