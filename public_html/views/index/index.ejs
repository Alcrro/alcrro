<%- include('../includes/head.ejs') %>


	<link rel="stylesheet" href="/css/style.css">

	<body>
		
    <%- include('../includes/navigation.ejs') %>

	<main>
			<%- include('../includes/leftnavigation.ejs') %>
			<%- include('../content/headcontent.ejs') %>

				<% if(prods.length > 0) { %>
						<div class="items-container">
							<% for(let product of prods) { %>
								
									<div class="card-container">

										<div class="img-container">

											<div class="icons-button">

												<i class='bx bx-shopping-bag'></i>

												<i class='bx bx-heart' ></i>

												<i class='bx bx-checkbox'></i>

											</div>

											<a href=""><img src="<%= product.imageUrl  %>" alt=""></a>

										</div>

										<div class="description-container">

											<a href=""><p><%= product.description %></p>

											</a>

										</div>

										<div class="stars-container">

											<a href="#">

												<span><i class="fa-regular fa-star"></i></span>

												<span><i class="fa-regular fa-star"></i></span>

												<span><i class="fa-regular fa-star"></i></span>

												<span><i class="fa-regular fa-star"></i></span>

												<span><i class="fa-regular fa-star"></i></span>

												<span class="reviews-container">

												rev

											</span>

											</a>

										</div>

										<div class="estimate-placeholder">

											<div class="semibold font-size-sm text-availability-in_stock">

												stock

											</div>

										</div>

										<div class="price-container">

											<p class="product-price">$ <%= product.price %></p>

										</div>

										<div class="button-container">

										<button type="submit" class="cart-button">Add To Cart</button>

										</div>
							</div>
						<% } %>
				</div>
		<% } else { %>
			<h1>Products not found!</h1>
		<% } %>
	</main>
<%- include('../includes/end.ejs') %>