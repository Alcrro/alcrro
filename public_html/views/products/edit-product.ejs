<%- include('../includes/head.ejs') %>

<link rel="stylesheet" href="/css/style.css">
<link rel="stylesheet" href="/css/login.css">
<link rel="stylesheet" href="/css/edit-product.css">



<body>

	<%- include('../includes/navigation.ejs') %>

	<main>

		<form name="" action="/add-product" method="post">
			<input type="hidden" name="_csrf" value="<%= csrfToken %>">
			<div class="auth-container">
				<div class="auth-panel">
					<div class="auth-panel-header"><h1>Salute!</h1></div>
					<div class="auth-panel-body">
						<form name="user_login" action="/admin/<% if (editing) { %>edit-product<% } else { %>add-product<% } %>" method="POST">
							<div class="auth-form-group">
								<label for="auth-label-user-login-email" class="auth-label-user-login-email">Adauga numele Produsului</label>
								<input type="text" id="auth-input-user-login-email" name="email" value="" class="auth-input-email">
							</div>
							<div class="auth-form-group">
								<label for="auth-user-login-password" class="auth-user-login-password">Selecteaza culorile disponibile Produsului</label>

								<div id="list1" class="dropdown-check-list" tabindex="100">
									<span class="anchor">Select Fruits</span>
									<ul class="items">
										<li><input type="checkbox" />Apple </li>
										<li><input type="checkbox" />Orange</li>
										<li><input type="checkbox" />Grapes </li>
										<li><input type="checkbox" />Berry </li>
										<li><input type="checkbox" />Mango </li>
										<li><input type="checkbox" />Banana </li>
										<li><input type="checkbox" />Tomato</li>
									</ul>
								</div>
								
							</div>
							<div class="auth-form-group">
								<button type="submit" id="" name=""	class="btn-primary auth-btn">Continua</button>
							</div>
						</form>
				
			</div>


		</form>


	</main>


	<%- include('../includes/end.ejs') %>